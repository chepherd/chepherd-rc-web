{
  "extends": "astro/tsconfigs/strictest",
  "include": ["src/**/*", "*.ts", "*.mjs", "*.config.*"],
  "exclude": ["dist", "node_modules", ".astro"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true
  }
}
